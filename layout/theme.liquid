<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ page_title }}</title>
  <meta name="description" content="{{ shop.meta_description }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:ital,wght@0,300;0,400;0,700;1,400&family=Space+Grotesk:wght@300;400;500;600;700&family=Noto+Sans+KR:wght@300;400;700;900&display=swap" rel="stylesheet">
  {{ content_for_header }}
  <link href="{{ 'theme.css' | asset_url }}" rel="stylesheet" />
</head>
<body>
  {% section 'header' %}

  {{ content_for_layout }}

  {% section 'social' %}
  {% section 'footer' %}

  <script src="{{ 'theme.js' | asset_url }}"></script>
  {{ content_for_footer }}
</body>
</html>