<!-- Converted from your index.html body (hero, sections, gallery, etc.) -->
<section id="hero">
  <div class="hero-bg-word" aria-hidden="true">충성</div>

  <div class="hero-logo-stamp">
    <img src="{{ 'IMG_1150.PNG' | asset_url }}" alt="모데라 NYSL" />
  </div>

  <p class="hero-eyebrow">NYC × SEOUL &nbsp;·&nbsp; All In. Always.</p>

  <h1 class="hero-title">
    MOD<span class="outline">ERA</span>
  </h1>

  <div class="hero-etymology">
    <div class="etym-item">
      <span class="etym-word">MODO</span>
      <div class="etym-stack">
        <span class="etym-meaning">All In</span>
        <span class="etym-sub">Complete commitment</span>
      </div>
    </div>
    <div class="etym-item">
      <span class="etym-word">ERA</span>
      <div class="etym-stack">
        <span class="etym-meaning">New Chapter</span>
        <span class="etym-sub">A new phase of being all in</span>
      </div>
    </div>
  </div>

  <div class="hero-bottom">
    <p class="hero-tagline">
      Appliquéd on global standards.<br />
      Where New York and Seoul intertwine.
    </p>
    <div class="hero-korean" aria-hidden="true">
      모두의 새로운 시대<br />
      문화에 충성하라
    </div>
  </div>

  <div class="hero-scroll-hint" aria-hidden="true">
    <span class="scroll-label">Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<div class="ticker-wrap" aria-hidden="true">
  <div class="ticker-track">
    <span class="ticker-item">NYC</span><span class="ticker-item ticker-dot">×</span>
    <span class="ticker-item">SEOUL</span><span class="ticker-item ticker-dot">×</span>
    <span class="ticker-item">ALL IN</span><span class="ticker-item ticker-dot">×</span>
    <span class="ticker-item">문화</span><span class="ticker-item ticker-dot">×</span>
    <span class="ticker-item">NEW ERA</span><span class="ticker-item ticker-dot">×</span>
    <span class="ticker-item">HERITAGE</span><span class="ticker-item ticker-dot">×</span>
    <span class="ticker-item">충성</span><span class="ticker-item ticker-dot">×</span>
    <span class="ticker-item">MODERA</span><span class="ticker-item ticker-dot">×</span>
  </div>
</div>

<div id="about">
  <div class="about-text reveal">
    <div class="section-label">The Mission</div>
    <h2 class="about-title">Introducing Korean history to modern-day New York City.</h2>
    <p class="about-body">
      Don't change for certain environments. Introduce your background to your current environment.
      Modera was built for the person who carries their roots into every room they enter—building a
      community, uniting the east and west.
    </p>
    <div class="about-pillars">
      <div class="about-pillar">
        <span class="pillar-en">Stay loyal to the culture</span>
        <span class="pillar-kr">문화에 충성하라</span>
      </div>
      <div class="about-pillar">
        <span class="pillar-en">Be true to yourself</span>
        <span class="pillar-kr">자신에게 솔직해라</span>
      </div>
      <div class="about-pillar">
        <span class="pillar-en">Find art in simple history</span>
        <span class="pillar-kr">역사 속에서 예술을</span>
      </div>
      <div class="about-pillar">
        <span class="pillar-en">Introducing Korean history to NYC</span>
        <span class="pillar-kr">한국의 역사를 뉴욕으로</span>
      </div>
    </div>
  </div>
  <div class="about-image reveal">
    <img src="{{ 'IMG_3095.PNG' | asset_url }}" alt="The struggle — two fighters representing the fight to stay true to your heritage" />
  </div>
</div>

<div id="identity">
  <div class="identity-panel nyc reveal">
    <div class="identity-panel-bg" aria-hidden="true">NEW<br/>YORK</div>
    <h3 class="identity-city">New<br/>York</h3>
    <p class="identity-desc">
      The urban standard. Global cuts, modern silhouettes — boxy hoodies and
      layered fits built for the streets that never sleep.
    </p>
  </div>
  <div class="identity-sep" aria-hidden="true">
    <span class="identity-x">×</span>
  </div>
  <div class="identity-panel seoul reveal">
    <div class="identity-panel-bg" aria-hidden="true">서울<br/>혼</div>
    <h3 class="identity-city">서울</h3>
    <p class="identity-desc">
      Korean typography overlaid on every silhouette. Heritage not as nostalgia,
      but as an active statement of who you are.
    </p>
  </div>
</div>

<div id="spirit">
  <div class="spirit-image reveal">
    <img src="{{ 'IMG_3097.PNG' | asset_url }}" alt="Modera boxing gloves — stay in the ring" />
  </div>
  <div class="spirit-text reveal">
    <div class="spirit-bg-word" aria-hidden="true">FIGHT</div>
    <div class="section-label red">The Spirit</div>
    <h2 class="spirit-title">Life is a bout.<br/>Stay in the ring.</h2>
    <p class="spirit-body">
      Gritty. Intentional. Deeply personal. The uniform for the modern-day warrior—shaped
      by the discipline of the boxing ring and the quiet dignity of one's ancestors.
    </p>
    <div class="spirit-glyphs">
      <div class="glyph-item">
        <span class="glyph-char">진도</span>
        <span class="glyph-label">Jindo — Stay Loyal</span>
      </div>
      <div class="glyph-item">
        <span class="glyph-char">全力</span>
        <span class="glyph-label">All In — Every Time</span>
      </div>
    </div>
  </div>
</div>

<section id="gallery">
  <div class="gallery-header reveal">
    <div class="gallery-header-left">
      <div class="section-label">First Edition</div>
      <h2 class="gallery-title">
        Appliquéd on<br/><span class="outline">Global Standards</span>
      </h2>
    </div>
    <p class="gallery-note">
      Every piece numbered and registered. Once an edition closes, it does not return.
      The metropolitan few who understand identity is built over time.
    </p>
  </div>

  {% comment %} Use a Shopify collection called "first-edition" if present. Falls back to static cards. {% endcomment %}
  {% if collections['first-edition'] and collections['first-edition'].products_count > 0 %}
    <div class="gallery-grid">
      {% for product in collections['first-edition'].products %}
        <div class="product-card reveal">
          <div class="product-img-wrap">
            <a href="{{ product.url }}">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title }}" />
              {% else %}
                <img src="{{ 'IMG_3135.PNG' | asset_url }}" alt="{{ product.title }}" />
              {% endif %}
            </a>
          </div>
          <div class="product-info">
            <div>
              <div class="product-name">{{ product.title }}</div>
              <div class="product-sub">{{ product.vendor }}{% if product.type %} · {{ product.type }}{% endif %}</div>
            </div>
            <div class="product-edition">No. {{ forloop.index }}</div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="gallery-grid">
      <div class="product-card reveal">
        <div class="product-img-wrap">
          <img src="{{ 'IMG_3135.PNG' | asset_url }}" alt="The Jindo Layer — Modera NYSL" />
        </div>
        <div class="product-info">
          <div>
            <div class="product-name">The Jindo Layer</div>
            <div class="product-sub">Layered Long Sleeve — First Edition</div>
          </div>
          <div class="product-edition">No. 01</div>
        </div>
      </div>

      <div class="product-card reveal">
        <div class="product-img-wrap">
          <img src="{{ 'IMG_3136.PNG' | asset_url }}" alt="The Bout — Modera NYSL" />
        </div>
        <div class="product-info">
          <div>
            <div class="product-name">The Bout</div>
            <div class="product-sub">Boxy Long Sleeve — First Edition</div>
          </div>
          <div class="product-edition">No. 02</div>
        </div>
      </div>

      <div class="product-card reveal">
        <div class="product-img-wrap">
          <img src="{{ 'IMG_3165.PNG' | asset_url }}" alt="The Jindo Hoodie — Modera NYSL" />
        </div>
        <div class="product-info">
          <div>
            <div class="product-name">The Jindo Hoodie</div>
            <div class="product-sub">Heavyweight Hoodie — First Edition</div>
          </div>
          <div class="product-edition">No. 03</div>
        </div>
      </div>

    </div>
  {% endif %}
</section>

<section id="jindo">
  <div class="reveal">
    <div class="section-label">The Symbol</div>
    <h2 class="jindo-title">The<br/>Loyalty<br/>of the<br/>Jindo</h2>
    <p class="jindo-body">
      The Jindo is a Korean national treasure — known for its unwavering loyalty
      and its instinct to always find its way home.
    </p>
    <div class="jindo-glyph-row">
      <span class="jindo-glyph-char">忠</span>
      <div class="jindo-glyph-text">
        <span class="jindo-glyph-label">충성 · Loyalty</span>
        <span class="jindo-glyph-sub">The way of the Jindo. The way of Modera.</span>
      </div>
    </div>
  </div>
  <div class="jindo-product-wrap reveal">
    <img src="{{ 'IMG_3135.PNG' | asset_url }}" alt="The Jindo Layer — heritage on global standards" />
  </div>
</section>

<section id="collection">
  <div class="reveal">
    <p class="collection-overline">Dropping Soon</p>
    <h2 class="collection-main-title">
      FIRST<br/><span class="no">EDITION</span>
    </h2>
    <p class="collection-sub">모두의 새로운 시대 &nbsp;·&nbsp; Everyone's New Era</p>
    <p class="collection-body">
      Every piece is numbered and registered. Once an edition closes, it does not return.
      Modera is built on a single rule: every garment must earn its place in a closet.
    </p>
  </div>
  <div class="collection-rules reveal">
    <div class="col-rule">
      <div class="col-rule-num">01</div>
      <div class="col-rule-label">Numbered</div>
      <div class="col-rule-desc">Every piece is individually numbered. Your unit is yours alone.</div>
    </div>
    <div class="col-rule">
      <div class="col-rule-num">02</div>
      <div class="col-rule-label">Registered</div>
      <div class="col-rule-desc">Each garment is registered to its owner at purchase.</div>
    </div>
    <div class="col-rule">
      <div class="col-rule-num">03</div>
      <div class="col-rule-label">Final</div>
      <div class="col-rule-desc">Once an edition closes, it does not reopen. No restocks.</div>
    </div>
  </div>
</section>

<section id="philosophy">
  <div class="section-label reveal">The Way</div>
  <div class="p-grid">
    <div class="p-card reveal">
      <div class="p-card-hover"></div>
      <div class="p-card-num">001</div>
      <h3 class="p-card-title">All In.<br/>Always.</h3>
      <p class="p-card-body">"Modo" — all. "Era" — a new chapter.</p>
      <div class="p-card-kr" aria-hidden="true">全</div>
    </div>
    <div class="p-card reveal">
      <div class="p-card-hover"></div>
      <div class="p-card-num">002</div>
      <h3 class="p-card-title">The Loyalty<br/>of the Jindo</h3>
      <p class="p-card-body">The Jindo knows only one path home — its own.</p>
      <div class="p-card-kr" aria-hidden="true">義</div>
    </div>
    <div class="p-card reveal">
      <div class="p-card-hover"></div>
      <div class="p-card-num">003</div>
      <h3 class="p-card-title">Built for the<br/>Metropolitan Few</h3>
      <p class="p-card-body">Not for everyone. For those who understand identity is built over time.</p>
      <div class="p-card-kr" aria-hidden="true">魂</div>
    </div>
  </div>
</section>

<section id="notify">
  <div class="reveal">
    <p class="notify-overline">Be First</p>
    <h2 class="notify-title">Get<br/>Notified</h2>
    <p class="notify-sub">The first edition is limited. Once it closes, it does not return.</p>
    <form class="notify-form" id="notifyForm" onsubmit="handleNotify(event)">
      <input class="notify-input" type="email" id="notifyEmail" placeholder="your@email.com" required autocomplete="email" />
      <button class="notify-btn" type="submit">Notify Me</button>
    </form>
    <p class="notify-note">No spam. First edition access only.</p>
    <p class="notify-success" id="notifySuccess">You're on the list. Stay loyal. 충성.</p>
  </div>
</section>